{
  "name": "@carepack/audit-logger",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "lint":  "tsc --noEmit",
    "test":  "jest --passWithNoTests"
  },
  "dependencies": {
    "pg":      "^8.12.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "@types/pg":   "^8.11.6",
    "jest":        "^29.7.0",
    "ts-jest":     "^29.2.2",
    "typescript":  "^5.5.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"],
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "module": "CommonJS",
          "moduleResolution": "node",
          "types": ["node", "jest"]
        }
      }
    }
  }
}
