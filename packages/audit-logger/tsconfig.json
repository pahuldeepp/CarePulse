{
  "compilerOptions": {
    "target":                  "ES2022",
    "module":                  "CommonJS",
    "moduleResolution":        "node",
    "strict":                  false,
    "esModuleInterop":         true,
    "skipLibCheck":            true,
    "declaration":             true,
    "outDir":                  "dist",
    "rootDir":                 "src"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
